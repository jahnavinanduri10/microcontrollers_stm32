int main()
{
    SPI2_GPIOInits();
    SPI2_Init();

    // software slave management
    SPI_SSIConfig(SPI2, ENABLE);
    SPI_SSOEConfig(SPI2, DISABLE);

    // enable SPI
    SPI_PeripheralControl(SPI2, ENABLE);

    delay();

    uint8_t dummy = 0xFF;

    // CS HIGH
    GPIO_WriteToOutputPin(GPIOB, GPIO_PIN_NO_12, SET);

    // give at least 74 clock cycles
    for(int i = 0; i < 20; i++)
    {
        SPI_TransmitReceive(SPI2, &dummy, &dummy, 1);
    }

    uint8_t resp;
    int retry = 0;

    do {
    	resp = SD_SendCommand_Read(0, 0x00000000, 0x95, NULL, 0);

        GPIO_WriteToOutputPin(GPIOB, GPIO_PIN_NO_12, SET);
        SPI_TransmitReceive(SPI2, &dummy, &dummy, 1);

        retry++;

    } while(resp != 0x01 && retry < 10);

    GPIO_WriteToOutputPin(GPIOB, GPIO_PIN_NO_12, SET);  // CS HIGH
    SPI_TransmitReceive(SPI2, &dummy, &dummy, 1);       // extra clock

    uint8_t r7[4];

    resp = SD_SendCommand_Read(8, 0x000001AA, 0x87, r7, 4);

    // NOW release CS
    GPIO_WriteToOutputPin(GPIOB, GPIO_PIN_NO_12, SET);
    SPI_TransmitReceive(SPI2, &dummy, &dummy, 1);

    do {
        // CMD55
        resp = SD_SendCommand_Read(55, 0, 0xFF, NULL, 0);

        GPIO_WriteToOutputPin(GPIOB, GPIO_PIN_NO_12, SET);
        SPI_TransmitReceive(SPI2, &dummy, &dummy, 1);

        // ACMD41 (HCS bit set)
        resp = SD_SendCommand_Read(41, 0x40000000, 0xFF, NULL, 0);

        GPIO_WriteToOutputPin(GPIOB, GPIO_PIN_NO_12, SET);
        SPI_TransmitReceive(SPI2, &dummy, &dummy, 1);

    } while(resp != 0x00);

    uint8_t ocr[4];

    resp = SD_SendCommand_Read(58, 0, 0xFF, ocr, 4);

    GPIO_WriteToOutputPin(GPIOB, GPIO_PIN_NO_12, SET);
    SPI_TransmitReceive(SPI2, &dummy, &dummy, 1);

    uint8_t data[512] = "Hello SD Card from STM32";

    uint8_t status = SD_WriteBlock(0, data);

    uint8_t rbuf[512];

    SD_ReadBlock(0, rbuf);
    while(1)
    {

    }
}


