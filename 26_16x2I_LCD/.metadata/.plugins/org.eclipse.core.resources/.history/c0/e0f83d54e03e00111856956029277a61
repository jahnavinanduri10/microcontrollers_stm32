void I2C_PeripheralControl(I2C_RegDef_t *pI2Cx, uint8_t EnorDi)
{
    if (EnorDi == ENABLE)
    {
        pI2Cx->CR1 |=  (1 << I2C_CR1_PE);
    }
    else
    {
        pI2Cx->CR1 &= ~(1 << I2C_CR1_PE);
    }
}

void I2C_PeriClockControl(I2C_RegDef_t *pI2Cx, uint8_t EnorDi)
{
    if (EnorDi == ENABLE)
    {
        if      (pI2Cx == I2C1) { I2C1_PCLK_EN(); }
        else if (pI2Cx == I2C2) { I2C2_PCLK_EN(); }
        else if (pI2Cx == I2C3) { I2C3_PCLK_EN(); }
    }
    else
    {
        if      (pI2Cx == I2C1) { I2C1_PCLK_DI(); }
        else if (pI2Cx == I2C2) { I2C2_PCLK_DI(); }
        else if (pI2Cx == I2C3) { I2C3_PCLK_DI(); }
    }
}


/*
 * I2C_Init
 *
 * Correct initialisation sequence (per RM0090 §27.3.3):
 *   1. Program FREQ in CR2
 *   2. Configure own address in OAR1
 *   3. Configure CCR
 *   4. Configure TRISE
 *   5. Enable PE (+ ACK if desired) in CR1
 */
void I2C_Init(I2C_Handle_t *pI2CHandle)
{
    uint32_t tempreg   = 0;
    uint32_t pclk1     = RCC_GetPCLK1Value();
    uint16_t ccr_value = 0;

    /* Enable peripheral clock before touching registers */
    I2C_PeriClockControl(pI2CHandle->pI2Cx, ENABLE);

    /* --- Software reset to clear any stuck BUSY/error state --- */
    pI2CHandle->pI2Cx->CR1 |=  (1 << I2C_CR1_SWRST);
    pI2CHandle->pI2Cx->CR1 &= ~(1 << I2C_CR1_SWRST);

    /* Enable peripheral clock before touching registers */
    I2C_PeriClockControl(pI2CHandle->pI2Cx, ENABLE);

    /* ---- CR2: FREQ field (APB1 clock in MHz) ---- */
    tempreg = pclk1 / 1000000U;
    pI2CHandle->pI2Cx->CR2 = (tempreg & 0x3F);

    /* ---- OAR1: own 7-bit address ----*/
    tempreg = 0;
    tempreg |= (pI2CHandle->I2C_Config.I2C_DeviceAddress << 1);
    tempreg |= (1 << 14);       /* Bit 14 must always be kept 1 (RM0090 note) */
    pI2CHandle->pI2Cx->OAR1 = tempreg;

    /* ---- CCR: clock control ---- */
    tempreg = 0;
    if (pI2CHandle->I2C_Config.I2C_SCLSpeed <= I2C_SCL_SPEED_SM)
    {
        /* Standard mode: T_high = T_low = CCR × T_PCLK1
         * CCR = Fpclk1 / (2 × Fscl) */
        ccr_value = (uint16_t)(pclk1 / (2 * pI2CHandle->I2C_Config.I2C_SCLSpeed));
        tempreg  |= (ccr_value & 0xFFF);
    }
    else
    {
        /* Fast mode */
        tempreg |= (1 << 15);   /* FS = 1 */
        tempreg |= (pI2CHandle->I2C_Config.I2C_FMDutyCycle << 14);

        if (pI2CHandle->I2C_Config.I2C_FMDutyCycle == I2C_FM_DUTY_2)
        {
            /* Duty = 0: T_low = 2×CCR, T_high = CCR → CCR = Fpclk1/(3×Fscl) */
            ccr_value = (uint16_t)(pclk1 / (3 * pI2CHandle->I2C_Config.I2C_SCLSpeed));
        }
        else
        {
            /* Duty = 1: T_low = 16×CCR, T_high = 9×CCR → CCR = Fpclk1/(25×Fscl) */
            ccr_value = (uint16_t)(pclk1 / (25 * pI2CHandle->I2C_Config.I2C_SCLSpeed));
        }

        tempreg |= (ccr_value & 0xFFF);
    }
    pI2CHandle->pI2Cx->CCR = tempreg;

    /* ---- TRISE ----
     *
     * Standard mode: t_rise(max) = 1000 ns  → TRISE = Fpclk1(MHz) + 1
     * Fast mode:     t_rise(max) =  300 ns  → TRISE = floor(Fpclk1(MHz) × 0.3) + 1
     */
    if (pI2CHandle->I2C_Config.I2C_SCLSpeed <= I2C_SCL_SPEED_SM)
    {
        tempreg = (pclk1 / 1000000U) + 1;
    }
    else
    {
        tempreg = ((pclk1 / 1000000U) * 300 / 1000) + 1;
    }
    pI2CHandle->pI2Cx->TRISE = (tempreg & 0x3F);

    /* ---- CR1: enable peripheral + ACK ----
     * ACK should be enabled here if the user requested it.
     */
    tempreg = (1 << I2C_CR1_PE);
    if (pI2CHandle->I2C_Config.I2C_ACKControl == I2C_ACK_ENABLE)
    {
        tempreg |= (1 << I2C_CR1_ACK);
    }
    pI2CHandle->pI2Cx->CR1 = tempreg;
}


void I2C_DeInit(I2C_RegDef_t *pI2Cx)
{
    /* Use APB1RSTR to reset the peripheral, then release */
    if      (pI2Cx == I2C1) { RCC->APB1RSTR |= (1 << 21); RCC->APB1RSTR &= ~(1 << 21); }
    else if (pI2Cx == I2C2) { RCC->APB1RSTR |= (1 << 22); RCC->APB1RSTR &= ~(1 << 22); }
    else if (pI2Cx == I2C3) { RCC->APB1RSTR |= (1 << 23); RCC->APB1RSTR &= ~(1 << 23); }
}



uint8_t I2C_GetFlagStatus(I2C_RegDef_t *pI2Cx, uint32_t FlagName)
{
    return (pI2Cx->SR1 & FlagName) ? FLAG_SET : FLAG_RESET;
}


void I2C_MasterSendData(I2C_Handle_t *pI2CHandle,uint8_t *pTxBuffer,uint32_t len,uint8_t SlaveAddr)
{
	/* Wait until bus is free — if stuck here, check pull-ups & wiring */
	while (pI2CHandle->pI2Cx->SR2 & (1 << I2C_SR2_BUSY));

	// 1. generate start condition
	I2C_GenerateStartCondition(pI2CHandle->pI2Cx);

	// confirm that start generation is conpleted by checking the SB clasj in SR1
	while( ! I2C_GetFlagStatus(pI2CHandle->pI2Cx,I2C_FLAG_SB));

	//Send the address of the slave with r/w bit set to w(0) (total 8 bits)
	I2C_ExecuteAddressPhaseWrite(pI2CHandle->pI2Cx,SlaveAddr);

	//confirm the address phase flag according to its software sequence
	while( ! I2C_GetFlagStatus(pI2CHandle->pI2Cx,I2C_FLAG_ADDR));

	// clear ADDR flag according to its software sequence
	I2C_ClearADDRFlag(pI2CHandle->pI2Cx);

	//send data until len become 0
	while(len>0)
	{
		while( ! I2C_GetFlagStatus(pI2CHandle->pI2Cx,I2C_FLAG_TXE));
		pI2CHandle->pI2Cx->DR = *pTxBuffer;
		pTxBuffer++;
		len--;
	}
	// when len become 0, wait for TXE=1 and BTF=1
	while( ! I2C_GetFlagStatus(pI2CHandle->pI2Cx,I2C_FLAG_TXE));
	while( ! I2C_GetFlagStatus(pI2CHandle->pI2Cx,I2C_FLAG_BTF));

	I2C_GenerateStopCondition(pI2CHandle->pI2Cx);
}



void I2C_MasterReceiveData(I2C_Handle_t *pI2CHandle,
                           uint8_t      *pRxBuffer,
                           uint32_t      len,
                           uint8_t       SlaveAddr)
{
    while (pI2CHandle->pI2Cx->SR2 & (1 << I2C_SR2_BUSY));

    /* 1. Generate START */
    I2C_GenerateStartCondition(pI2CHandle->pI2Cx);

    /* 2. Wait until SB is set */
    while (!I2C_GetFlagStatus(pI2CHandle->pI2Cx, I2C_FLAG_SB));

    /* 3. Send slave address with Read bit */
    I2C_ExecuteAddressPhaseRead(pI2CHandle->pI2Cx, SlaveAddr);

    /* 4. Wait until ADDR flag is set */
    while (!I2C_GetFlagStatus(pI2CHandle->pI2Cx, I2C_FLAG_ADDR));

    /* ---------- Single byte reception ---------- */
    if (len == 1)
    {
        /* Disable ACK before clearing ADDR so NACK is sent automatically */
        I2C_ManageAcking(pI2CHandle->pI2Cx, I2C_ACK_DISABLE);

        /* Clear ADDR (this releases SCL and the slave will send its byte) */
        I2C_ClearADDRFlag(pI2CHandle->pI2Cx);

        /* Wait for data to arrive */
        while (!I2C_GetFlagStatus(pI2CHandle->pI2Cx, I2C_FLAG_RXNE));

        /* Generate STOP before reading DR so master releases bus on time */
        I2C_GenerateStopCondition(pI2CHandle->pI2Cx);

        /* Read the single byte */
        *pRxBuffer = (uint8_t)pI2CHandle->pI2Cx->DR;

        return;
    }

    /* ---------- Multiple byte reception ---------- */
    if (len > 1)
    {
        /* Clear ADDR to release SCL and let slave start sending */
        I2C_ClearADDRFlag(pI2CHandle->pI2Cx);

        for (uint32_t i = len; i > 0; i--)
        {
            /* Wait until byte is in DR */
            while (!I2C_GetFlagStatus(pI2CHandle->pI2Cx, I2C_FLAG_RXNE));

            if (i == 2)
            {
                /*
                 * Disable ACK NOW (so the NACK goes out after the next byte),
                 * then generate STOP. Do this BEFORE reading DR so the
                 * hardware has time to act on the next SCL pulse.
                 */
                I2C_ManageAcking(pI2CHandle->pI2Cx, I2C_ACK_DISABLE);
                I2C_GenerateStopCondition(pI2CHandle->pI2Cx);
            }

            /* Read the received byte */
            *pRxBuffer = (uint8_t)pI2CHandle->pI2Cx->DR;
            pRxBuffer++;
        }
    }

    /* Re-enable ACK if it was configured that way */
    if (pI2CHandle->I2C_Config.I2C_ACKControl == I2C_ACK_ENABLE)
    {
        I2C_ManageAcking(pI2CHandle->pI2Cx, I2C_ACK_ENABLE);
    }
}





void I2C_ManageAcking(I2C_RegDef_t *pI2Cx, uint8_t EnorDi)
{
	if(EnorDi == I2C_ACK_ENABLE)
	{
		pI2Cx->CR1|= ( 1<< I2C_CR1_ACK);
	}
	else
	{
		pI2Cx->CR1 &= ~( 1<< I2C_CR1_ACK);
	}
}




